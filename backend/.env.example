# Example .env for backend (DO NOT commit real secrets)

# Database. MySQL example: mysql+pymysql://user:password@host:3306/dbname
# Leave blank to fall back to a local SQLite file (sqlite:///./atsboost.db) for dev.
DATABASE_URL=mysql+pymysql://ats_user:ats_pass@db:3306/atsboost

# Set to "true" to log all SQL statements (debugging only)
SQLALCHEMY_ECHO=false

# --- AI provider configuration ---
# Provider selection: leave blank to auto-detect (OpenRouter if OPENROUTER_API_KEY
# is set, otherwise Gemini). Or force one explicitly: "openrouter" or "gemini".
LLM_PROVIDER=

# Gemini (Google generative AI) key
GEMINI_API_KEY=

# OpenRouter — has free models (https://openrouter.ai/keys). When this key is set
# OpenRouter is used automatically. Default model is a free one; override as needed.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Cloudinary credentials for file uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS - comma separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# App secret (use a strong random value in production)
SECRET_KEY=change-me
